{
  "name": "topview-svg-mapper",
  "private": true,
  "version": "0.1.0",
  "description": "TopView SVG Mapper -- reconstructs a 2D top-down SVG floor plan from a walkthrough video, via a plugin-extensible feature-detection pipeline.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@topview/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-unknown",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-unknown",
    "clean": "rimraf \"apps/*/dist\" \"packages/*/dist\" \"plugins/*/dist\"",
    "verify-deps": "node scripts/verify-dependency-graph.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.0"
  }
}
