{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topview.dev/schema/project-document.schema.json",
  "title": "ProjectDocument",
  "description": "Mirrors the ProjectDocument interface in packages/schema/src/project-format.ts -- the on-disk/IndexedDB/backend-persisted shape of one TopView project. Used by services/reconstruction-api's CI contract-sync check (docs/architecture.md §7); per-entity-kind validation (e.g. a wall) is factored out into sibling schemas such as wall.schema.json rather than inlined here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectId",
    "name",
    "createdAt",
    "updatedAt",
    "computeMode",
    "sourceMedia",
    "entities",
    "layers",
    "activeLayerId",
    "cameraPoses",
    "completedStages",
    "currentVersionId"
  ],
  "properties": {
    "projectId": { "type": "string" },
    "name": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "computeMode": { "enum": ["local", "backend", "cloud"] },
    "sourceMedia": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "enum": ["video", "image-sequence"] },
        "uri": { "type": "string" },
        "frameCount": { "type": "integer", "minimum": 0 },
        "durationSeconds": { "type": "number", "minimum": 0 },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "entities": {
      "type": "object",
      "description": "Keyed by EntityId. Values are one of the AnyEntity kinds (wall, corner, door, window, room, furniture); see wall.schema.json for the reference validation shape of one kind.",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "kind", "layerId", "confidence", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["wall", "corner", "door", "window", "room", "furniture"] }
        }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "visible", "locked", "order"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "visible": { "type": "boolean" },
          "locked": { "type": "boolean" },
          "order": { "type": "integer" }
        }
      }
    },
    "activeLayerId": { "type": "string" },
    "cameraPoses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["frameId", "position", "rotationQuaternion"],
        "properties": {
          "frameId": { "type": "string" },
          "position": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          },
          "rotationQuaternion": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": { "type": "number" }
          }
        }
      }
    },
    "pointCloud": {
      "type": "object",
      "required": ["id", "runId", "storage"],
      "properties": {
        "id": { "type": "string" },
        "runId": { "type": "string" },
        "storage": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "points"],
              "properties": {
                "mode": { "const": "inline" },
                "points": { "type": "array" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "uri", "format", "pointCount"],
              "properties": {
                "mode": { "const": "external" },
                "uri": { "type": "string" },
                "format": { "enum": ["ply", "las", "pcd"] },
                "pointCount": { "type": "integer", "minimum": 0 }
              }
            }
          ]
        }
      }
    },
    "completedStages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "completedAt"],
        "properties": {
          "stage": {
            "enum": [
              "upload",
              "frame-extraction",
              "feature-detection",
              "camera-reconstruction",
              "point-cloud-generation",
              "geometry-recovery",
              "wall-detection",
              "furniture-detection",
              "layout-generation",
              "svg-cleanup",
              "export"
            ]
          },
          "completedAt": { "type": "string", "format": "date-time" },
          "pluginId": { "type": "string" }
        }
      }
    },
    "currentVersionId": { "type": ["string", "null"] }
  }
}
