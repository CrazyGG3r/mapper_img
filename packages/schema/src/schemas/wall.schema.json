{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topview.dev/schema/wall.schema.json",
  "title": "Wall",
  "description": "Mirrors the Wall interface in packages/schema/src/entities.ts. One entity-kind sample used by services/reconstruction-api's CI contract-sync check (docs/architecture.md §7).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "layerId",
    "confidence",
    "createdAt",
    "updatedAt",
    "start",
    "end",
    "thicknessM"
  ],
  "properties": {
    "id": { "type": "string" },
    "kind": { "const": "wall" },
    "layerId": { "type": "string" },
    "confidence": { "$ref": "#/$defs/confidenceMeta" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "start": { "$ref": "#/$defs/point2d" },
    "end": { "$ref": "#/$defs/point2d" },
    "thicknessM": { "type": "number", "exclusiveMinimum": 0 },
    "heightM": { "type": "number", "exclusiveMinimum": 0 },
    "startCornerId": { "type": "string" },
    "endCornerId": { "type": "string" }
  },
  "$defs": {
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "confidenceMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "source", "validationStatus"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "enum": ["detector", "user", "imported"] },
        "sourcePluginId": { "type": "string" },
        "validationStatus": {
          "enum": ["unreviewed", "user-accepted", "user-rejected", "user-edited"]
        },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "type": "string" }
      }
    }
  }
}
