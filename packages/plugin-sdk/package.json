{
  "name": "@topview/plugin-sdk",
  "private": true,
  "version": "0.1.0",
  "description": "Contract every TopView plugin (and the pipeline runner) is built against: plugin interfaces, the manifest shape, and the PluginRegistry.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@topview/schema": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "rimraf": "^6.0.0"
  }
}
