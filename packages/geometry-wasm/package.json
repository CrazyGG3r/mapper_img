{
  "name": "@topview/geometry-wasm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Perf-critical geometry kernels (point-cloud downsampling, polygon simplification) with a wasm-bindgen/Rust backend and a pure-JS fallback.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:wasm": "node scripts/build-wasm.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@topview/schema": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
