{
  "name": "@topview/svg-engine",
  "private": true,
  "version": "0.1.0",
  "description": "SVG generation, geometry cleanup (merge/snap/orthogonalize), and multi-format export (SVG/DXF/JSON/GeoJSON/OBJ/GLTF/PLY) for the TopView project scene graph.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@topview/schema": "*",
    "@topview/geometry-wasm": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "rimraf": "^6.0.0"
  }
}
